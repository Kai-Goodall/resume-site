---
import { getCollection } from "astro:content";
import { ViewTransitions } from "astro:transitions";
import "../styles/app.css";

const work = [
  {
    company: "Waterloo Rocketry",
    title: "Propulsion Subsystem Member",
    description: "end-to-end fabrication, static fire operations, materials R&D, brazing development",
    time: "Sep 2024 – present",
    link: "https://www.waterloorocketry.com/",
  },
  {
    company: "ODF / Merge",
    title: "Technical Program Lead",
    description: "technical due diligence on 2,000+ applications; distributed $35k+ to 44 projects → $6M+ follow-on",
    time: "Apr 2024 – present",
    link: "https://joinodf.com/",
  },
  {
    company: "Solideon",
    title: "Additive Manufacturing Engineering Intern",
    description: "robotic WAAM calibration, FDM prototyping, fixture engineering for large aluminum parts",
    time: "Jun – Sep 2024",
    link: "https://solideon.com/",
  },
  {
    company: "Telesat",
    title: "IV&V Systems Engineering Intern",
    description: "LEO constellation network emulation, requirements & lifecycle management for 300+ engineers",
    time: "Jul – Dec 2023",
    link: "https://www.telesat.com/",
  },
  {
    company: "Retro",
    title: "Growth Intern",
    description: "growth strategy, contractor management, influencer outreach",
    time: "2025",
    link: "https://retro.app",
  },
  {
    company: "Omi",
    title: "Contract Hardware Designer",
    description: "part design, manufacturing support",
    time: "2023",
    link: "https://www.omi.me/",
  },
  {
    company: "Mercury Filmworks",
    title: "IT Intern",
    description: "software and hardware support, computer assembly, inventory management",
    time: "2021 – 2023",
    link: "https://mercuryfilmworks.com/",
  },
  {
    company: "Ottawa River Runners",
    title: "Lead Whitewater Kayaking Instructor",
    description: "lead instructor for whitewater kayaking, canoe, and raft programs",
    time: "2022 – 2024",
    link: "https://ottawariverrunners.com/",
  },
];

const projects = [
  {
    name: "Pikipiki Rafiki",
    description: "motorcycle distribution & financing to break cycles of poverty in rural Tanzania · 1st at TKS Earthshot",
    link: "https://youtu.be/XAOPtdqA9sk",
  },
  {
    name: "Garage Liquid Rocket Engine",
    description: "$1,000 grant from 1517 Fund to design & build a fluid-powered jet propulsion system",
    link: "https://1517fund.com/",
  },
  {
    name: "SmartStudy (Amazon Alexa)",
    description: "AI study assistant turning lecture recordings into notes & practice questions · pitched to Alexa exec team",
    link: "https://www.youtube.com/watch?v=JCjhUJCZmhg",
  },
  {
    name: "BenchSci Wellbeing Tool",
    description: "LLM-powered employee productivity & mental health tracker · implemented by BenchSci engineers",
    link: "https://www.youtube.com/watch?v=NfB7msbEv8c",
  },
  {
    name: "NeuroShield",
    description: "EEG + rTMS glasses to detect and suppress opioid cravings",
    link: "https://robbieliu4.editorx.io/neuroshield",
  },
  {
    name: "Bagel Fund",
    description: "technical specialist at a microgrant program run with friends",
    link: "https://bagel.fund/",
  },
];

const skills = [
  { category: "Design & Simulation", items: "Fusion360, SolidWorks, AutoCAD, ANSYS (FEA/CFD), MATLAB, Python" },
  { category: "Manufacturing", items: "CNC & Manual Machining (Mill/Lathe), MIG/TIG Welding, FDM/SLM/WAAM" },
  { category: "Electronics & Controls", items: "Soldering, Embedded Systems (ESP32), C++, Git, CLI" },
];

const hobbies = [
  { name: "Whitewater Sports", description: "kayaking, canoeing, rafting — former lead kayaking instructor (2022–2024)" },
  { name: "Extreme Downhill Skiing", description: "" },
  { name: "Music", description: "saxophone, flute, piano" },
  { name: "Film Photography", description: "" },
];

const speaking = [
  { name: "World Summit AI", description: "Montreal" },
  { name: "C2 MTL", description: "Montreal" },
  { name: "Collision Conference", description: "Toronto" },
];

const additionals = [
  { name: "LinkedIn", link: "https://www.linkedin.com/in/kaigoodall" },
  { name: "Twitter", link: "https://x.com/mcmgoodall" },
  { name: "Email", link: "mailto:kgoodall@uwaterloo.ca" },
  { name: "GitHub", link: "https://github.com/Kai-Goodall" },
  { name: "Resume", link: "/resume.pdf" },
];

const blog = await getCollection("blog");

const posts = blog
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
  )
  .map((post) => ({
    params: { slug: post.slug, title: post.data.title, link: post.data.link },
    props: post,
  }));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Kai Goodall</title>
    <link
      rel="preload"
      href="/fonts/BerkeleyMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <ViewTransitions />
  </head>
  <div class="flex min-h-screen p-8 max-w-4xl m-auto" transition:animate="fade">
    <div class="my-auto w-full">
      <div class="flex space-x-12 font-mono">
        <p class="font-bold text-2xl font-mono">Kai Goodall</p>
      </div>
      <div class="mt-2">
        <p class="font-mono">
          Mechanical Engineering student at the University of Waterloo (BASc, Co-op, exp. Apr 2030).<br /><br />
          Propulsion engineer at Waterloo Rocketry and Technical Program Lead at ODF/Merge. I build rocket engines, robotic manufacturing systems, and the programs that fund other builders.
        </p>
      </div>

      <div class="mt-8">
        <p class="font-bold font-mono text-xl">Experience</p>
        <div class="mt-4 space-y-3 md:space-y-1">
          {
            work.map((job) => (
              <a class="grid md:flex md:justify-between" href={job.link}>
                <div class="flex space-x-2">
                  <p class="font-mono font-bold whitespace-nowrap hover:underline hover:cursor-pointer">
                    {job.company} ({job.time})
                  </p>
                </div>
                <p class="font-mono md:text-right max-w-xs">{job.description}</p>
              </a>
            ))
          }
        </div>
      </div>

      <div class="mt-8">
        <p class="font-bold font-mono text-xl">Projects</p>
        <div class="mt-4 space-y-3 md:space-y-1">
          {
            projects.map((project) => (
              <a class="grid md:flex md:justify-between" href={project.link}>
                <p class="font-mono font-bold whitespace-nowrap hover:underline hover:cursor-pointer">
                  {project.name}
                </p>
                <p class="font-mono md:text-right">{project.description}</p>
              </a>
            ))
          }
        </div>
      </div>

      <div class="mt-8">
        <p class="font-bold font-mono text-xl">Skills</p>
        <div class="mt-4 space-y-1">
          {
            skills.map((s) => (
              <div class="grid md:flex md:justify-between">
                <p class="font-mono font-bold whitespace-nowrap">{s.category}</p>
                <p class="font-mono md:text-right max-w-xs">{s.items}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="mt-8">
        <p class="font-bold font-mono text-xl">Education</p>
        <div class="mt-4">
          <div class="grid md:flex md:justify-between">
            <p class="font-mono font-bold">University of Waterloo</p>
            <p class="font-mono md:text-right">BASc Mechanical Engineering, Co-op · exp. Apr 2030</p>
          </div>
          <p class="font-mono text-sm mt-1">President's Scholarship ($2,000 · 95%+ avg) · Dean's List: Winter 2025</p>
        </div>
      </div>

      {posts.length > 0 && (
        <div class="mt-8">
          <p class="font-bold font-mono text-xl">Posts</p>
          <div class="mt-4 space-y-3 md:space-y-1">
            {
              posts.map((post) => (
                <a
                  class="grid md:flex md:justify-between"
                  href={
                    !post.props.data.link
                      ? `/blog/${post.props.slug}`
                      : post.props.data.link
                  }
                >
                  <p class="font-mono font-bold whitespace-nowrap hover:underline hover:cursor-pointer">
                    {post.props.data.title}
                  </p>
                  <p class="font-mono text-black truncate">
                    {post.props.data.description}
                  </p>
                </a>
              ))
            }
          </div>
        </div>
      )}

      <div class="mt-8">
        <p class="font-bold font-mono text-xl">Interests</p>
        <div class="mt-4 space-y-1">
          {
            hobbies.map((h) => (
              <div class="grid md:flex md:justify-between">
                <p class="font-mono font-bold">{h.name}</p>
                {h.description && <p class="font-mono md:text-right">{h.description}</p>}
              </div>
            ))
          }
        </div>
        <div class="mt-3">
          <p class="font-mono font-bold">Speaker / Panelist</p>
          <p class="font-mono">World Summit AI (Montreal) · C2 MTL · Collision Conference (Toronto)</p>
        </div>
      </div>

      <div class="mt-8">
        <hr class="my-4 border-gray-300" />
        <div class="mt-4">
          <div class="grid md:flex md:justify-between">
            {
              additionals.map((link) => (
                <a
                  href={link.link}
                  class="hover:underline hover:cursor-pointer"
                >
                  <p class="font-bold font-mono">{link.name}</p>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</html>
