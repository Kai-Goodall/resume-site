    description: "propulsion research, testing, & manufacturing",
    time: "Sep 2024 – present",
    link: "https://www.waterloorocketry.com/",
    icon: "https://www.google.com/s2/favicons?domain=waterloorocketry.com&sz=64",
  },
  {
    company: "ODF / Merge",
    description: "project review & program operations",
    time: "Apr 2024 – present",
    link: "https://joinodf.com/",
    icon: "https://www.google.com/s2/favicons?domain=joinodf.com&sz=64",
  },
  {
    company: "Retro",
    description: "growth, contractor operations, & outreach",
    time: "2025",
    link: "https://retro.app",
    icon: "https://www.google.com/s2/favicons?domain=retro.app&sz=64",
  },
  {
    company: "Solideon",
    description: "additive manufacturing & robotics",
    time: "Jun – Sep 2024",
    link: "https://solideon.com/",
    icon: "https://www.google.com/s2/favicons?domain=solideon.com&sz=64",
  },
  {
    company: "Omi",
    description: "hardware design & manufacturing for open-source AI wearables",
    time: "2024",
    link: "https://www.omi.me/",
    icon: "https://www.google.com/s2/favicons?domain=omi.me&sz=64",
  },
  {
    company: "Telesat",
    description: "systems engineering & network validation",
    time: "Jul – Dec 2023",
    link: "https://www.telesat.com/",
    icon: "https://www.google.com/s2/favicons?domain=telesat.com&sz=64",
  },
  {
    company: "Ottawa River Runners",
    description: "whitewater instruction & safety",
    time: "2022 – 2024",
    link: "https://ottawariverrunners.com/",
    icon: "https://www.google.com/s2/favicons?domain=ottawariverrunners.com&sz=64",
  },
  {
    company: "Mercury Filmworks",
    description: "IT support, computer assembly, & inventory",
    time: "2023",
    link: "https://mercuryfilmworks.com/",
    icon: "https://www.google.com/s2/favicons?domain=mercuryfilmworks.com&sz=64",
  },
];

const projects = [
  {
    name: "Pikipiki Rafiki",
    description: "motorcycle distribution & financing to break cycles of poverty in rural Tanzania · 1st at TKS Earthshot",
    link: "https://youtu.be/XAOPtdqA9sk",
  },
  {
    name: "Garage Liquid Rocket Engine",
    description: "$1,000 grant from 1517 Fund to design & build a fluid-powered jet propulsion system",
    link: "https://1517fund.com/",
  },
  {
    name: "SmartStudy (Amazon Alexa)",
    description: "AI study assistant turning lecture recordings into notes & practice questions · pitched to Alexa exec team",
    link: "https://www.youtube.com/watch?v=JCjhUJCZmhg",
  },
  {
    name: "BenchSci Wellbeing Tool",
    description: "LLM-powered employee productivity & mental health tracker · implemented by BenchSci engineers",
    link: "https://www.youtube.com/watch?v=NfB7msbEv8c",
  },
  {
    name: "NeuroShield",
    description: "EEG + rTMS glasses to detect and suppress opioid cravings",
    link: "https://robbieliu4.editorx.io/neuroshield",
  },
  {
    name: "Bagel Fund",
    description: "technical specialist at a microgrant program run with friends",
