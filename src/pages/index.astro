  },
];

const skills = [
  { category: "Design & Simulation", items: "Fusion360, SolidWorks, AutoCAD, ANSYS (FEA/CFD), MATLAB, Python" },
  { category: "Manufacturing", items: "CNC & Manual Machining (Mill/Lathe), MIG/TIG Welding, FDM/SLM/WAAM" },
  { category: "Electronics & Controls", items: "Soldering, Embedded Systems (ESP32), C++, Git, CLI" },
];

const hobbies = [
  { name: "Whitewater Sports", description: "kayaking, canoeing, rafting — former lead kayaking instructor (2022–2024)" },
  { name: "Extreme Downhill Skiing", description: "" },
  { name: "Music", description: "saxophone, flute, piano" },
  { name: "Film Photography", description: "" },
];

const additionals = [
  { name: "LinkedIn", link: "https://www.linkedin.com/in/kaigoodall" },
  { name: "Twitter", link: "https://x.com/mcmgoodall" },
  { name: "Email", link: "mailto:kgoodall@uwaterloo.ca" },
  { name: "GitHub", link: "https://github.com/Kai-Goodall" },
  { name: "Resume", link: "/resume.pdf" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚙️</text></svg>" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Kai Goodall</title>
    <link
      rel="preload"
      href="/fonts/BerkeleyMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <ViewTransitions />
  </head>
  <div class="flex min-h-screen p-8 max-w-4xl m-auto" transition:animate="fade">
    <div class="my-auto w-full">

      <p class="font-bold text-2xl font-mono">Kai Goodall</p>
      <p class="font-mono mt-1">Propulsion engineer at Waterloo Rocketry and Technical Program Lead at ODF/Merge.</p>
      <p class="font-mono text-black/60 text-sm mt-1">mechanical engineering, rocketry, additive manufacturing, and building programs for ambitious builders.</p>

      <div class="mt-6">
        <p class="font-bold font-mono text-lg">Experience</p>
        <div class="mt-2">
          {
            work.map((job, i) => (
              <div class="flex gap-2">
                <div class="flex flex-col items-center shrink-0">
                  <img src={job.icon} alt={`${job.company} logo`} width="24" height="24" class="w-6 h-6 shrink-0 rounded-sm" />
                  {i < work.length - 1 && (
                    <span class="font-mono text-black/30 select-none text-xs leading-none py-0.5">|</span>
                  )}
                </div>
                <a class="grid md:flex md:justify-between w-full mb-0.5" href={job.link}>
                  <p class="font-mono whitespace-nowrap hover:underline hover:cursor-pointer">
                    <span class="font-bold">{job.company}</span>&nbsp;<span class="text-black/40">({job.time})</span>
                  </p>
                  <p class="font-mono md:text-right md:max-w-xs">{job.description}</p>
                </a>
              </div>
            ))
          }
        </div>
      </div>

      <div class="mt-6">
        <p class="font-bold font-mono text-lg">Education</p>
        <div class="mt-2 flex gap-2">
          <img src="https://www.google.com/s2/favicons?domain=uwaterloo.ca&sz=64" alt="University of Waterloo logo" width="24" height="24" class="w-6 h-6 shrink-0 rounded-sm mt-0.5" />
          <div class="w-full">
            <div class="grid md:flex md:justify-between">
              <p class="font-mono">
                <span class="font-bold">University of Waterloo</span>&nbsp;<span class="text-black/40">(exp. Apr 2030)</span>
              </p>
              <p class="font-mono md:text-right">BASc Mechanical Engineering, Co-op</p>
            </div>
            <p class="font-mono text-sm text-black/60 mt-0.5">President's Scholarship ($2,000 · 95%+ avg) · Dean's List: Winter 2025</p>
          </div>
        </div>
      </div>

      <div class="mt-6">
        <p class="font-bold font-mono text-lg">Projects</p>
        <div class="mt-2 space-y-1">
          {
            projects.map((project) => (
              <a class="grid md:flex md:justify-between" href={project.link}>
                <p class="font-mono font-bold whitespace-nowrap hover:underline hover:cursor-pointer">{project.name}</p>
                <p class="font-mono md:text-right md:max-w-xs">{project.description}</p>
              </a>
            ))
          }
        </div>
      </div>

      <div class="mt-6">
        <p class="font-bold font-mono text-lg">Skills</p>
        <div class="mt-2 space-y-1">
          {
            skills.map((s) => (
              <div class="grid md:flex md:justify-between">
                <p class="font-mono font-bold whitespace-nowrap">{s.category}</p>
                <p class="font-mono md:text-right md:max-w-xs">{s.items}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="mt-6">
        <p class="font-bold font-mono text-lg">Interests</p>
        <div class="mt-2 space-y-1">
          {
            hobbies.map((h) => (
              <div class="grid md:flex md:justify-between">
                <p class="font-mono font-bold whitespace-nowrap">{h.name}</p>
                {h.description && <p class="font-mono md:text-right">{h.description}</p>}
              </div>
            ))
          }
          <div class="grid md:flex md:justify-between">
            <p class="font-mono font-bold whitespace-nowrap">Speaker / Panelist</p>
            <p class="font-mono md:text-right">World Summit AI (Montreal) · C2 MTL · Collision Conference (Toronto)</p>
          </div>
        </div>
      </div>

      <div class="mt-6 font-mono text-sm text-black/50">
        <p class="select-none">---</p>
        <div class="mt-1 flex flex-wrap gap-x-2">
          {
            additionals.map((item, i) => (
              <>
                <a href={item.link} class="hover:text-black transition-colors">
                  [{item.name.toLowerCase()}]
                </a>
                {i < additionals.length - 1 && <span class="select-none">/</span>}
              </>
            ))
          }
        </div>
      </div>

    </div>
  </div>
</html>
